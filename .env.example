# Copie este arquivo para `.env` e ajuste os valores conforme necessário.
# `.env` não é versionado (ver .gitignore).

# Semente global usada para reprodutibilidade (splits, inicialização de
# modelos, amostragem em baselines).
RANDOM_SEED=42

# Diretório onde os dados brutos/processados ficam armazenados.
DATA_DIR=data

# Diretório onde artefatos de modelo treinados são salvos localmente.
MODELS_DIR=models

# URI do servidor de tracking do MLflow (local ou remoto).
MLFLOW_TRACKING_URI=http://localhost:5000
